      "digest": {
        "published": "2025-10-03",
        "description": "The WPRecovery plugin for WordPress is vulnerable to SQL Injection via the 'data[id]' parameter in all versions up to, and including, 2.0. This is due to insufficient escaping on the user supplied parameter and lack of sufficient preparation on the existing SQL query. This makes it possible for unauthenticated attackers to append additional SQL queries into already existing queries that can be used to extract sensitive information from the database. Additionally, the result of this SQL injection is passed directly to PHP's unlink() function, allowing attackers to delete arbitrary files on the server by injecting file paths through the SQL query.",
        "title": "The WPRecovery plugin for WordPress is vulnerable to SQL Injection via the 'data[id]' parameter in all versions up to, and including, 2.0.",
        "attack_type": "SQL Injection",
        "cvss_max": 9.1
      },
      "cve": {
        "id": "CVE-2025-10726",
        "sourceIdentifier": "security@wordfence.com",
        "published": "2025-10-03T12:15:43.417",
        "lastModified": "2026-04-15T00:35:42.020",
        "vulnStatus": "Deferred",
        "descriptions": [
          {
            "lang": "en",
            "value": "The WPRecovery plugin for WordPress is vulnerable to SQL Injection via the 'data[id]' parameter in all versions up to, and including, 2.0. This is due to insufficient escaping on the user supplied parameter and lack of sufficient preparation on the existing SQL query. This makes it possible for unauthenticated attackers to append additional SQL queries into already existing queries that can be used to extract sensitive information from the database. Additionally, the result of this SQL injection is passed directly to PHP's unlink() function, allowing attackers to delete arbitrary files on the server by injecting file paths through the SQL query."
          }
        ],
