      "digest": {
        "published": "2025-09-09",
        "description": "rAthena is an open-source cross-platform massively multiplayer online role playing game (MMORPG) server. Versions prior to commit 2f5248b have a heap-based buffer overflow in the login server, remote attacker to overwrite adjacent session fields by sending a crafted `CA_SSO_LOGIN_REQ` with an oversized token length. This leads to immediate denial of service (crash) and it is possible to achieve remote code execution via heap corruption. Commit 2f5248b fixes the issue.",
        "title": "rathena rathena Buffer Overflow",
        "vendor": "rathena",
        "product": "rathena",
        "attack_type": "Buffer Overflow",
        "cvss_max": 9.8
      },
      "cve": {
        "id": "CVE-2025-58447",
        "sourceIdentifier": "security-advisories@github.com",
        "published": "2025-09-09T23:15:36.497",
        "lastModified": "2025-09-17T20:53:21.610",
        "vulnStatus": "Analyzed",
        "descriptions": [
          {
            "lang": "en",
            "value": "rAthena is an open-source cross-platform massively multiplayer online role playing game (MMORPG) server. Versions prior to commit 2f5248b have a heap-based buffer overflow in the login server, remote attacker to overwrite adjacent session fields by sending a crafted `CA_SSO_LOGIN_REQ` with an oversized token length. This leads to immediate denial of service (crash) and it is possible to achieve remote code execution via heap corruption. Commit 2f5248b fixes the issue."
          }
        ],
