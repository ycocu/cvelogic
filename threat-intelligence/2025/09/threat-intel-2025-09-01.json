      "digest": {
        "published": "2025-09-01",
        "description": "A vulnerability in the h2oai/h2o-3 repository allows attackers to exploit deserialization of untrusted data, potentially leading to arbitrary code execution and reading of system files. This issue affects the latest master branch version 3.47.0.99999. The vulnerability arises from the ability to bypass regular expression filters intended to prevent malicious parameter injection in JDBC connections. Attackers can manipulate spaces between parameters to evade detection, allowing for unauthorized file access and code execution. The vulnerability is addressed in version 3.46.0.8.",
        "title": "RCE",
        "attack_type": "RCE",
        "cvss_max": 9.8
      },
      "cve": {
        "id": "CVE-2025-6507",
        "sourceIdentifier": "security@huntr.dev",
        "published": "2025-09-01T06:15:35.790",
        "lastModified": "2026-04-15T00:35:42.020",
        "vulnStatus": "Deferred",
        "descriptions": [
          {
            "lang": "en",
            "value": "A vulnerability in the h2oai/h2o-3 repository allows attackers to exploit deserialization of untrusted data, potentially leading to arbitrary code execution and reading of system files. This issue affects the latest master branch version 3.47.0.99999. The vulnerability arises from the ability to bypass regular expression filters intended to prevent malicious parameter injection in JDBC connections. Attackers can manipulate spaces between parameters to evade detection, allowing for unauthorized file access and code execution. The vulnerability is addressed in version 3.46.0.8."
          }
        ],
