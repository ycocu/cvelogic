      "digest": {
        "published": "2025-09-10",
        "description": "An SQL injection vulnerability has been identified in the \"ID\" attribute of the SAML response when the replay cache of the Shibboleth Service Provider (SP) is configured to use an SQL database as storage service. An unauthenticated attacker can exploit this issue via blind SQL injection, allowing for the extraction of arbitrary data from the database, if the database connection is configured to use the ODBC plugin. The vulnerability arises from insufficient escaping of single quotes in the class SQLString (file odbc-store.cpp, lines 253-271).\n\nThis issue affects Shibboleth Service Provider through 3.5.0.",
        "title": "An SQL injection vulnerability has been identified in the \"ID\" attribute of the SAML response when the replay cache of the Shibboleth Ser...",
        "attack_type": "SQL Injection",
        "cvss_max": 9.1
      },
      "cve": {
        "id": "CVE-2025-9943",
        "sourceIdentifier": "551230f0-3615-47bd-b7cc-93e92e730bbf",
        "published": "2025-09-10T07:15:47.153",
        "lastModified": "2026-04-15T00:35:42.020",
        "vulnStatus": "Deferred",
        "descriptions": [
          {
            "lang": "en",
            "value": "An SQL injection vulnerability has been identified in the \"ID\" attribute of the SAML response when the replay cache of the Shibboleth Service Provider (SP) is configured to use an SQL database as storage service. An unauthenticated attacker can exploit this issue via blind SQL injection, allowing for the extraction of arbitrary data from the database, if the database connection is configured to use the ODBC plugin. The vulnerability arises from insufficient escaping of single quotes in the class SQLString (file odbc-store.cpp, lines 253-271).\n\nThis issue affects Shibboleth Service Provider through 3.5.0."
          }
        ],
