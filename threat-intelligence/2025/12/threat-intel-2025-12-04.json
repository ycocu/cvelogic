      "digest": {
        "published": "2025-12-04",
        "description": "The Thermo Fisher Torrent Suite Django application 5.18.1 has weak default credentials, which are stored as fixtures for the Django ORM API. The ionadmin user account can be used to authenticate to default deployments with the password ionadmin. The user guide recommends changing default credentials; however, a password change policy for default administrative accounts is not enforced. Many deployments may retain default credentials, in which case an attacker is likely to be able to successfully authenticate with administrative privileges.",
        "title": "thermofisher torrent_suite_software",
        "vendor": "thermofisher",
        "product": "torrent_suite_software",
        "cvss_max": 9.8
      },
      "cve": {
        "id": "CVE-2025-54303",
        "sourceIdentifier": "cve@mitre.org",
        "published": "2025-12-04T15:15:58.633",
        "lastModified": "2025-12-16T21:00:13.787",
        "vulnStatus": "Analyzed",
        "descriptions": [
          {
            "lang": "en",
            "value": "The Thermo Fisher Torrent Suite Django application 5.18.1 has weak default credentials, which are stored as fixtures for the Django ORM API. The ionadmin user account can be used to authenticate to default deployments with the password ionadmin. The user guide recommends changing default credentials; however, a password change policy for default administrative accounts is not enforced. Many deployments may retain default credentials, in which case an attacker is likely to be able to successfully authenticate with administrative privileges."
          }
        ],
        "metrics": {
