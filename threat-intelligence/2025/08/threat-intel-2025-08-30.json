      "digest": {
        "published": "2025-08-30",
        "description": "BS.Player version 2.57 (build 1051) contains a vulnerability in its playlist import functionality. When processing .m3u files, the application fails to properly validate the length of playlist entries, resulting in a buffer overflow condition. This flaw occurs during parsing of long URLs embedded in the playlist, allowing overwrite of Structured Exception Handler (SEH) records. The vulnerability is triggered upon opening a crafted playlist file and affects the Unicode parsing logic in the Windows client.",
        "title": "BS.Player version 2.57 (build 1051) contains a vulnerability in its playlist import functionality.",
        "attack_type": "Buffer Overflow",
        "cvss_max": 10.0
      },
      "cve": {
        "id": "CVE-2010-10016",
        "sourceIdentifier": "disclosure@vulncheck.com",
        "published": "2025-08-30T14:15:37.180",
        "lastModified": "2026-04-15T00:35:42.020",
        "vulnStatus": "Deferred",
        "descriptions": [
          {
            "lang": "en",
            "value": "BS.Player version 2.57 (build 1051) contains a vulnerability in its playlist import functionality. When processing .m3u files, the application fails to properly validate the length of playlist entries, resulting in a buffer overflow condition. This flaw occurs during parsing of long URLs embedded in the playlist, allowing overwrite of Structured Exception Handler (SEH) records. The vulnerability is triggered upon opening a crafted playlist file and affects the Unicode parsing logic in the Windows client."
          }
        ],
