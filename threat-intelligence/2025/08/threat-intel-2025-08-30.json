      "digest": {
        "published": "2025-08-30",
        "description": "Dogfood CRM version 2.0.10 contains a remote command execution vulnerability in the spell.php script used by its mail subsystem. The vulnerability arises from unsanitized user input passed via a POST request to the data parameter, which is processed by the underlying shell without adequate escaping. This allows attackers to inject arbitrary shell commands and execute them on the server. The flaw is exploitable without authentication and was discovered by researcher LSO.",
        "title": "Dogfood CRM version 2.0.10 contains a remote command execution vulnerability in the spell.php script used by its mail subsystem.",
        "cvss_max": 9.3
      },
      "cve": {
        "id": "CVE-2009-20010",
        "sourceIdentifier": "disclosure@vulncheck.com",
        "published": "2025-08-30T14:15:34.877",
        "lastModified": "2026-04-15T00:35:42.020",
        "vulnStatus": "Deferred",
        "descriptions": [
          {
            "lang": "en",
            "value": "Dogfood CRM version 2.0.10 contains a remote command execution vulnerability in the spell.php script used by its mail subsystem. The vulnerability arises from unsanitized user input passed via a POST request to the data parameter, which is processed by the underlying shell without adequate escaping. This allows attackers to inject arbitrary shell commands and execute them on the server. The flaw is exploitable without authentication and was discovered by researcher LSO."
          }
        ],
