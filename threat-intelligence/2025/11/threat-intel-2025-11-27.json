      "digest": {
        "published": "2025-11-27",
        "description": "Mattermost versions 10.12.x <= 10.12.1, 10.11.x <= 10.11.4, 10.5.x <= 10.5.12, 11.0.x <= 11.0.3 fail to properly validate OAuth state tokens during OpenID Connect authentication which allows an authenticated attacker with team creation privileges to take over a user account via manipulation of authentication data during the OAuth completion flow. This requires email verification to be disabled (default: disabled), OAuth/OpenID Connect to be enabled, and the attacker to control two users in the SSO system with one of them never having logged into Mattermost.",
        "title": "mattermost mattermost_server privilege escalation",
        "vendor": "mattermost",
        "product": "mattermost_server",
        "attack_type": "privilege escalation",
        "cvss_max": 9.9
      },
      "cve": {
        "id": "CVE-2025-12419",
        "sourceIdentifier": "responsibledisclosure@mattermost.com",
        "published": "2025-11-27T16:15:46.957",
        "lastModified": "2025-12-03T15:17:16.337",
        "vulnStatus": "Analyzed",
        "descriptions": [
          {
            "lang": "en",
            "value": "Mattermost versions 10.12.x <= 10.12.1, 10.11.x <= 10.11.4, 10.5.x <= 10.5.12, 11.0.x <= 11.0.3 fail to properly validate OAuth state tokens during OpenID Connect authentication which allows an authenticated attacker with team creation privileges to take over a user account via manipulation of authentication data during the OAuth completion flow. This requires email verification to be disabled (default: disabled), OAuth/OpenID Connect to be enabled, and the attacker to control two users in the SSO system with one of them never having logged into Mattermost."
          }
        ],
