      "digest": {
        "published": "2025-11-07",
        "description": "In pig-mesh Pig versions 3.8.2 and below, when setting up scheduled tasks in the Quartz management function under the system management module, it is possible to execute any Java class with a parameterless constructor and its methods with parameter type String through reflection. At this time, the eval method in Tomcat's built-in class jakarta.el.ELProcessor can be used to execute commands, leading to a remote code execution vulnerability.",
        "title": "pig4cloud pig",
        "vendor": "pig4cloud",
        "product": "pig",
        "cvss_max": 9.1
      },
      "cve": {
        "id": "CVE-2025-63690",
        "sourceIdentifier": "cve@mitre.org",
        "published": "2025-11-07T16:15:42.690",
        "lastModified": "2025-12-08T16:10:04.333",
        "vulnStatus": "Analyzed",
        "descriptions": [
          {
            "lang": "en",
            "value": "In pig-mesh Pig versions 3.8.2 and below, when setting up scheduled tasks in the Quartz management function under the system management module, it is possible to execute any Java class with a parameterless constructor and its methods with parameter type String through reflection. At this time, the eval method in Tomcat's built-in class jakarta.el.ELProcessor can be used to execute commands, leading to a remote code execution vulnerability."
          }
        ],
