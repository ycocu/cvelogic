      "digest": {
        "published": "2025-11-14",
        "description": "TG8 Firewall contains a pre-authentication remote code execution vulnerability in the runphpcmd.php endpoint. The syscmd POST parameter is passed directly to a system command without validation and executed with root privileges. A remote, unauthenticated attacker can supply crafted values to execute arbitrary operating system commands as root, resulting in full device compromise.",
        "title": "TG8 Firewall contains a pre-authentication remote code execution vulnerability in the runphpcmd.php endpoint.",
        "attack_type": "RCE",
        "cvss_max": 9.3
      },
      "cve": {
        "id": "CVE-2021-4470",
        "sourceIdentifier": "disclosure@vulncheck.com",
        "published": "2025-11-14T23:15:43.087",
        "lastModified": "2026-04-15T00:35:42.020",
        "vulnStatus": "Deferred",
        "descriptions": [
          {
            "lang": "en",
            "value": "TG8 Firewall contains a pre-authentication remote code execution vulnerability in the runphpcmd.php endpoint. The syscmd POST parameter is passed directly to a system command without validation and executed with root privileges. A remote, unauthenticated attacker can supply crafted values to execute arbitrary operating system commands as root, resulting in full device compromise."
          }
        ],
