      "digest": {
        "published": "2025-11-26",
        "description": "XML-Sig versions 0.27 through 0.67 for Perl incorrectly validates XML files if signatures are omitted.\n\nAn attacker can remove the signature from the XML document to make it pass the verification check.\n\nXML-Sig is a Perl module to validate signatures on XML files.  An unsigned XML file should return an error message.  The affected versions return true when attempting to validate an XML file that contains no signatures.",
        "title": "xml::sig_project xml::sig",
        "vendor": "xml\\",
        "product": "\\",
        "cvss_max": 9.3
      },
      "cve": {
        "id": "CVE-2025-40934",
        "sourceIdentifier": "9b29abf9-4ab0-4765-b253-1875cd9b441e",
        "published": "2025-11-26T23:15:47.773",
        "lastModified": "2025-12-30T15:21:37.487",
        "vulnStatus": "Analyzed",
        "descriptions": [
          {
            "lang": "en",
            "value": "XML-Sig versions 0.27 through 0.67 for Perl incorrectly validates XML files if signatures are omitted.\n\nAn attacker can remove the signature from the XML document to make it pass the verification check.\n\nXML-Sig is a Perl module to validate signatures on XML files.  An unsigned XML file should return an error message.  The affected versions return true when attempting to validate an XML file that contains no signatures."
          }
        ],
        "metrics": {
