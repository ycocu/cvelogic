      "digest": {
        "published": "2026-04-04",
        "description": "Snews CMS 1.7 contains an unrestricted file upload vulnerability that allows unauthenticated attackers to upload arbitrary files including PHP executables to the snews_files directory. Attackers can upload malicious PHP files through the multipart form-data upload endpoint and execute them by accessing the uploaded file path to achieve remote code execution.",
        "title": "snewscms snews RCE",
        "vendor": "snewscms",
        "product": "snews",
        "attack_type": "RCE",
        "cvss_max": 9.8
      },
      "cve": {
        "id": "CVE-2016-20052",
        "sourceIdentifier": "disclosure@vulncheck.com",
        "published": "2026-04-04T14:16:17.520",
        "lastModified": "2026-04-14T19:05:45.853",
        "vulnStatus": "Analyzed",
        "descriptions": [
          {
            "lang": "en",
            "value": "Snews CMS 1.7 contains an unrestricted file upload vulnerability that allows unauthenticated attackers to upload arbitrary files including PHP executables to the snews_files directory. Attackers can upload malicious PHP files through the multipart form-data upload endpoint and execute them by accessing the uploaded file path to achieve remote code execution."
          }
