      "digest": {
        "published": "2026-05-25",
        "description": "Szafir SDK returns a success status code from the cryptographic digital signature verification process (i.e. /VerifyingTaskItem/Signature/VerificationResult/Result/@code == 0, \"Positively verified\") even when the trust status of the signer's certificate could not be established (i.e. /VerifyingTaskItem/Signature/VerificationResult/SigningCertificate/@certificateType == \"nondetermined\"). This causes consuming applications to incorrectly treat the signature as valid despite an unverified certificate chain, enabling authentication bypass and user impersonation.\n\nThis issue was fixed in version 463.",
        "title": "Szafir SDK returns a success status code from the cryptographic digital signature verification process (i.e.",
        "cvss_max": 9.3
      },
      "cve": {
        "id": "CVE-2026-9058",
        "sourceIdentifier": "cvd@cert.pl",
        "published": "2026-05-25T14:16:27.977",
        "lastModified": "2026-05-26T19:59:22.323",
        "vulnStatus": "Deferred",
        "descriptions": [
          {
            "lang": "en",
            "value": "Szafir SDK returns a success status code from the cryptographic digital signature verification process (i.e. /VerifyingTaskItem/Signature/VerificationResult/Result/@code == 0, \"Positively verified\") even when the trust status of the signer's certificate could not be established (i.e. /VerifyingTaskItem/Signature/VerificationResult/SigningCertificate/@certificateType == \"nondetermined\"). This causes consuming applications to incorrectly treat the signature as valid despite an unverified certificate chain, enabling authentication bypass and user impersonation.\n\nThis issue was fixed in version 463."
          }
        ],
