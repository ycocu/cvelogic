      "digest": {
        "published": "2026-01-02",
        "description": "gpsd before commit dc966aa contains a heap-based out-of-bounds write vulnerability in the drivers/driver_nmea2000.c file. The hnd_129540 function, which handles NMEA2000 PGN 129540 (GNSS Satellites in View) packets, fails to validate the user-supplied satellite count against the size of the skyview array (184 elements). This allows an attacker to write beyond the bounds of the array by providing a satellite count up to 255, leading to memory corruption, Denial of Service (DoS), and potentially arbitrary code execution.",
        "title": "gpsd_project gpsd Out-of-Bounds Write",
        "vendor": "gpsd_project",
        "product": "gpsd",
        "attack_type": "Out-of-Bounds Write",
        "cvss_max": 9.8
      },
      "cve": {
        "id": "CVE-2025-67268",
        "sourceIdentifier": "cve@mitre.org",
        "published": "2026-01-02T16:17:00.990",
        "lastModified": "2026-01-12T15:33:45.577",
        "vulnStatus": "Analyzed",
        "descriptions": [
          {
            "lang": "en",
            "value": "gpsd before commit dc966aa contains a heap-based out-of-bounds write vulnerability in the drivers/driver_nmea2000.c file. The hnd_129540 function, which handles NMEA2000 PGN 129540 (GNSS Satellites in View) packets, fails to validate the user-supplied satellite count against the size of the skyview array (184 elements). This allows an attacker to write beyond the bounds of the array by providing a satellite count up to 255, leading to memory corruption, Denial of Service (DoS), and potentially arbitrary code execution."
          }
        ],
