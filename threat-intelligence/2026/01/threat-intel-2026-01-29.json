      "digest": {
        "published": "2003-03-24",
        "description": "The try_uudecoding function in mail-format.c for Ximian Evolution Mail User Agent 1.2.2 and earlier allows remote attackers to cause a denial of service (crash) and possibly execute arbitrary code via a malicious uuencoded (UUE) header, possibly triggering a heap-based buffer overflow.",
        "title": "ximian evolution Buffer Overflow",
        "vendor": "ximian",
        "product": "evolution",
        "attack_type": "Buffer Overflow",
        "cvss_max": 5.0
      },
      "cve": {
        "id": "CVE-2003-0128",
        "sourceIdentifier": "cve@mitre.org",
        "published": "2003-03-24T05:00:00.000",
        "lastModified": "2026-04-16T00:27:16.627",
        "vulnStatus": "Modified",
        "descriptions": [
          {
            "lang": "en",
            "value": "The try_uudecoding function in mail-format.c for Ximian Evolution Mail User Agent 1.2.2 and earlier allows remote attackers to cause a denial of service (crash) and possibly execute arbitrary code via a malicious uuencoded (UUE) header, possibly triggering a heap-based buffer overflow."
          },
          {
            "lang": "es",
            "value": "La función try_uudecoding en mail-format.c en Ximian Evolution Mail User Agent 1.2.2 y anteriores permite a atacantes remotos causar una denegación de servicio (caída) y posiblemente ejecutar código arbitrario mediante una cabecera \"uu-codificada\" (UUE) de manera maliciosa, posiblemente disparando un desbordamiento de búfer basado en el montón (heap)."
          }
        ],
